# ComplianceAstra Backend - Environment Variables
# Copy to .env and fill in values

# Database - use sync URL for migrations (postgresql://), async for app (postgresql+asyncpg://)
DATABASE_URL=postgresql://user:pass@localhost:5432/complianceastra

# Auth - generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# CORS - frontend URL
CORS_ORIGINS=["http://localhost:3000"]

# Stripe (optional for dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_REPORT=
# Set STRIPE_DEV_BYPASS=true to skip Stripe and redirect to success (dev only)
STRIPE_DEV_BYPASS=false
FRONTEND_URL=http://localhost:3000

# Resend (https://resend.com) — REQUIRED for any email after payment, forgot-password, etc.
# Without RESEND_API_KEY, checkout still works (PDF + in-app set-password) but NO email is sent.
RESEND_API_KEY=
# Use a verified domain in Resend, or "onboarding@resend.dev" for quick tests (Resend docs).
MAIL_FROM=
